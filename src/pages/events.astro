---
import Layout from "../layouts/Layout.astro";
const CALENDAR_ID = 'YOUR_CALENDAR_ID@group.calendar.google.com';
const API_KEY = 'YOUR_API_KEY';
---
<Layout title="PlayGames - Spartanburg's Premier Card & Game Shop">
    <div
            class="min-h-screen text-gray-200"
            style="background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);"
    >
        <div class="max-w-7xl mx-auto px-4 py-12">
            <!-- Header -->
            <header class="text-center mb-12">
                <h1
                        class="text-4xl font-bold mb-4"
                        style="background: linear-gradient(135deg, #667eea, #764ba2);
                   -webkit-background-clip: text;
                   -webkit-text-fill-color: transparent;">
                    Upcoming Events
                </h1>
                <p class="text-gray-400 max-w-2xl mx-auto">
                    Join us for tournaments, casual play, and community events.
                </p>
            </header>
    
            <!-- States -->
            <div id="loading" class="text-center py-12">
                <div class="animate-spin h-12 w-12 border-b-2 border-purple-500 rounded-full mx-auto"></div>
                <p class="mt-4 text-gray-400">Loading events...</p>
            </div>
    
            <div id="error" class="hidden text-center py-12">
                <p class="text-red-400 mb-2">Unable to load calendar events</p>
                <p class="text-gray-400 text-sm">Showing example events</p>
            </div>
    
            <!-- Events Grid -->
            <div
                    id="events-grid"
                    class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
            ></div>
        </div>
    
        <!-- Modal -->
        <div
                id="modal"
                class="fixed inset-0 hidden items-center justify-center bg-black/80 p-4 z-50"
        >
            <div
                    id="modal-content"
                    class="max-w-2xl w-full rounded-xl p-6 relative"
                    style="background: linear-gradient(135deg, #0f0c29, #302b63);
                 border: 2px solid #6c63ff;"
            >
                <button
                        id="close-modal"
                        class="absolute top-4 right-4 text-xl"
                >
                    ✕
                </button>
    
                <div id="modal-body"></div>
            </div>
        </div>
    </div>
</Layout>
<script is:inline>

    const loadingEl = document.getElementById('loading');
    const errorEl = document.getElementById('error');
    const gridEl = document.getElementById('events-grid');
    const modalEl = document.getElementById('modal');
    const modalBody = document.getElementById('modal-body');
    const closeModalBtn = document.getElementById('close-modal');

    const CALENDAR_ID = "{{CALENDAR_ID}}";
    const API_KEY = "{{API_KEY}}";

    function formatDate(dateStr) {
        return new Date(dateStr).toLocaleDateString('en-US', {
            weekday: 'long',
            month: 'long',
            day: 'numeric',
            year: 'numeric'
        });
    }

    function formatTime(dateStr) {
        return new Date(dateStr).toLocaleTimeString('en-US', {
            hour: 'numeric',
            minute: '2-digit'
        });
    }

    function daysUntil(dateStr) {
        const diff = Math.ceil(
            (new Date(dateStr) - new Date()) / (1000 * 60 * 60 * 24)
        );
        if (diff === 0) return 'Today';
        if (diff === 1) return 'Tomorrow';
        if (diff < 7) return `In ${diff} days`;
        return '';
    }

    function getMockEvents() {
        return [
            {
                id: '1',
                summary: 'Friday Night Magic',
                description: 'Weekly MTG tournament with prizes.',
                location: 'PlayGames, Spartanburg, SC',
                start: { dateTime: '2025-01-03T18:00:00-05:00' },
                end: { dateTime: '2025-01-03T22:00:00-05:00' }
            }
        ];
    }

    function renderEvents(events) {
        loadingEl.classList.add('hidden');
        gridEl.classList.remove('hidden');

        gridEl.innerHTML = '';

        events.forEach(event => {
            const card = document.createElement('div');
            card.className =
                'cursor-pointer rounded-xl p-6 transition hover:-translate-y-1';
            card.style.background = 'rgba(15,12,41,0.6)';
            card.style.border = '1px solid rgba(108,99,255,0.3)';

            card.innerHTML = `
        ${daysUntil(event.start.dateTime)
                ? `<span class="inline-block text-xs px-3 py-1 mb-3 rounded-full bg-purple-600">
               ${daysUntil(event.start.dateTime)}
             </span>`
                : ''}

        <h3 class="text-xl font-bold mb-2 text-purple-400">
          ${event.summary}
        </h3>

        <p class="text-sm text-gray-300">
          ${formatDate(event.start.dateTime)}<br>
          ${formatTime(event.start.dateTime)} – ${formatTime(event.end.dateTime)}
        </p>

        <p class="mt-3 text-gray-400 text-sm">
          ${event.description || ''}
        </p>
      `;

            card.addEventListener('click', () => openModal(event));
            gridEl.appendChild(card);
        });
    }

    function openModal(event) {
        modalBody.innerHTML = `
      <h2 class="text-2xl font-bold mb-4 text-purple-400">
        ${event.summary}
      </h2>
      <p class="mb-2">${formatDate(event.start.dateTime)}</p>
      <p class="mb-2">
        ${formatTime(event.start.dateTime)} – ${formatTime(event.end.dateTime)}
      </p>
      <p class="mt-4 text-gray-300">${event.description || ''}</p>
    `;
        modalEl.classList.remove('hidden');
        modalEl.classList.add('flex');
    }

    closeModalBtn.addEventListener('click', () => {
        modalEl.classList.add('hidden');
        modalEl.classList.remove('flex');
    });

    modalEl.addEventListener('click', e => {
        if (e.target === modalEl) closeModalBtn.click();
    });

    async function loadEvents() {
        try {
            const now = new Date().toISOString();
            const url =
                `https://www.googleapis.com/calendar/v3/calendars/${CALENDAR_ID}/events` +
                `?key=${API_KEY}&timeMin=${now}&singleEvents=true&orderBy=startTime`;

            const res = await fetch(url);
            if (!res.ok) throw new Error();

            const data = await res.json();
            renderEvents(data.items || []);
        } catch {
            errorEl.classList.remove('hidden');
            renderEvents(getMockEvents());
        }
    }

    loadEvents();
</script>
