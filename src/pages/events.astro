---
import Layout from "../layouts/Layout.astro";
import '../styles/events.css';
---
<Layout title="PlayGames - Events | Spartanburg's Premier Card & Game Shop">
    <div id="eventsMain" class="min-h-screen text-gray-200 page-background">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
            <!-- Header -->
            <header class="text-center mb-8 sm:mb-12">
                <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-4 gradient-text">
                    Upcoming Events
                </h1>
                <p class="text-base sm:text-lg lg:text-xl text-gray-400 max-w-2xl mx-auto px-4">
                    Join us for tournaments, casual play, and community events. All skill levels welcome!
                </p>
            </header>

            <!-- Loading State -->
            <div id="loading" class="text-center py-12">
                <div class="inline-block animate-spin h-12 w-12 border-b-2 border-purple-500 rounded-full"></div>
                <p class="mt-4 text-gray-400">Loading events...</p>
            </div>

            <!-- Error State -->
            <div id="error" class="hidden text-center py-12">
                <p class="text-red-400 mb-4">Unable to load events from calendar</p>
                <p class="text-gray-400 text-sm">Showing example events below</p>
            </div>

            <!-- Events Grid -->
            <div id="events-grid"
                 class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
            </div>

            <!-- No Events -->
            <div id="no-events" class="hidden text-center py-12">
                <svg class="w-16 h-16 mx-auto mb-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                <p class="text-xl text-gray-400">No upcoming events scheduled</p>
                <p class="text-gray-500 mt-2">Check back soon for new events!</p>
            </div>
        </div>

        <!-- Modal -->
        <div id="modal"
             class="fixed inset-0 hidden items-center justify-center modal-overlay p-4 z-50">
            <div id="modal-content"
                 class="max-w-2xl w-full max-h-[90vh] overflow-y-auto rounded-xl p-6 sm:p-8 relative modal-content">
                <button id="close-modal"
                        class="absolute top-4 right-4 p-2 rounded-full transition-colors hover:bg-gray-700"
                        aria-label="Close modal">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>

                <div id="modal-body" class="pr-8"></div>
            </div>
        </div>
    </div>
</Layout>

<script is:inline>
    const loadingEl = document.getElementById('loading');
    const errorEl = document.getElementById('error');
    const gridEl = document.getElementById('events-grid');
    const noEventsEl = document.getElementById('no-events');
    const modalEl = document.getElementById('modal');
    const modalBody = document.getElementById('modal-body');
    const closeModalBtn = document.getElementById('close-modal');

    // Google Calendar Configuration
    const CALENDAR_ID = "141c871f248f963c32f2a16fa07f3f9b7547a6af855219879ca68175c47925c9@group.calendar.google.com";
    const API_KEY = "AIzaSyDaJmNe4Gcfc4PTn-8VOZn1vtwb33FUlj0";

    // Date/Time Formatting Functions
    function formatDate(dateStr) {
        return new Date(dateStr).toLocaleDateString('en-US', {
            weekday: 'long',
            month: 'long',
            day: 'numeric',
            year: 'numeric'
        });
    }

    function formatTime(dateStr) {
        return new Date(dateStr).toLocaleTimeString('en-US', {
            hour: 'numeric',
            minute: '2-digit',
            hour12: true
        });
    }

    function daysUntil(dateStr) {
        const eventDate = new Date(dateStr);
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        eventDate.setHours(0, 0, 0, 0);

        const diff = Math.ceil((eventDate - today) / (1000 * 60 * 60 * 24));

        if (diff === 0) return 'Today';
        if (diff === 1) return 'Tomorrow';
        if (diff < 7 && diff > 0) return `In ${diff} days`;
        return '';
    }



    // Render Events to Grid
    function renderEvents(events) {
        loadingEl.classList.add('hidden');

        if (events.length === 0) {
            noEventsEl.classList.remove('hidden');
            return;
        }

        gridEl.classList.remove('hidden');
        gridEl.innerHTML = '';

        events.forEach(event => {
            const card = document.createElement('div');
            card.className = 'event-card';

            const daysBadge = daysUntil(event.start.dateTime);

            card.innerHTML = `
                ${daysBadge ? `
                    <div class="days-badge">
                        ${daysBadge}
                    </div>
                ` : ''}
                
                <h3 class="event-summary">
                    ${event.summary}
                </h3>
                
                <div class="event-info">
                    <div class="event-info-row">
                      <svg
                        class="event-info-row__icon event-info-row__icon--date"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                        ></path>
                      </svg>
                      <span>${formatDate(event.start.dateTime)}</span>
                    </div>

                    
                 <div class="event-info-row">
                        <svg 
                            class="event-info-row__icon event-info-row__icon--date" 
                            fill="none" 
                            stroke="currentColor"
                             viewBox="0 0 24 24">
                            <path 
                                stroke-linecap="round" 
                                stroke-linejoin="round" 
                                stroke-width="2" 
                                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                            ></path>
                        </svg>
                        <span>${formatTime(event.start.dateTime)} - ${formatTime(event.end.dateTime)}</span>
                    </div>
                    
                    ${event.location ? `
                 <div class="event-info-row">
                            <svg 
                                class="event-info-row__icon event-info-row__icon--date" 
                                fill="none" 
                                stroke="currentColor" 
                                viewBox="0 0 24 24"
                                >
                                <path 
                                    stroke-linecap="round" 
                                    stroke-linejoin="round" 
                                    stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                ></path>
                                <path 
                                    stroke-linecap="round" 
                                    stroke-linejoin="round" 
                                    stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                                ></path>
                            </svg>
                            <span>${event.location}</span>
                        </div>
                    ` : ''}
                </div>
                
                <p class="description">
                  ${event.description || 'Click for more details'}
                </p>
                
                <button class="details-btn">
                  View Details →
                </button>
            `;

            card.addEventListener('click', () => openModal(event));
            gridEl.appendChild(card);
        });
    }

    // Open Modal with Event Details
    function openModal(event) {
        const daysBadge = daysUntil(event.start.dateTime);

        modalBody.innerHTML = `
            ${daysBadge ? `
                <div class="inline-block px-4 py-1.5 rounded-full text-sm font-semibold mb-4"
                     style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                    ${daysBadge}
                </div>
            ` : ''}

            <h2 class="text-2xl sm:text-3xl font-bold mb-6" style="color: #667eea;">
                ${event.summary}
            </h2>

            <div class="space-y-4 mb-6">
                <div class="flex items-start gap-3 text-gray-300">
                    <svg class="w-6 h-6 mt-0.5 flex-shrink-0" style="color: #6c63ff;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                    <div>
                        <p class="font-semibold">Date</p>
                        <p>${formatDate(event.start.dateTime)}</p>
                    </div>
                </div>

                <div class="flex items-start gap-3 text-gray-300">
                    <svg class="w-6 h-6 mt-0.5 flex-shrink-0" style="color: #6c63ff;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <div>
                        <p class="font-semibold">Time</p>
                        <p>${formatTime(event.start.dateTime)} - ${formatTime(event.end.dateTime)}</p>
                    </div>
                </div>

                ${event.location ? `
                    <div class="flex items-start gap-3 text-gray-300">
                        <svg class="w-6 h-6 mt-0.5 flex-shrink-0" style="color: #6c63ff;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                        <div>
                            <p class="font-semibold">Location</p>
                            <p>${event.location}</p>
                        </div>
                    </div>
                ` : ''}

                ${event.attendees ? `
                    <div class="flex items-start gap-3 text-gray-300">
                        <svg class="w-6 h-6 mt-0.5 flex-shrink-0" style="color: #6c63ff;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                        </svg>
                        <div>
                            <p class="font-semibold">Expected Attendance</p>
                            <p>${event.attendees}</p>
                        </div>
                    </div>
                ` : ''}
            </div>

            ${event.description ? `
                <div class="mb-6">
                    <h3 class="text-lg font-semibold mb-2" style="color: #667eea;">
                        Event Details
                    </h3>
                    <p class="text-gray-300 leading-relaxed whitespace-pre-wrap">
                        ${event.description}
                    </p>
                </div>
            ` : ''}

            <div class="flex flex-col sm:flex-row gap-3">                
                ${event.htmlLink ? `
                    <a href="${event.htmlLink}" target="_blank" rel="noopener noreferrer"
                       class="flex-1 px-6 py-3 rounded-full font-semibold transition-all flex items-center justify-center gap-2"
                       style="border: 2px solid #667eea; color: #667eea;">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                        </svg>
                        View in Calendar
                    </a>
                ` : ''}
            </div>
        `;

        // Add hover effect to register button
        const registerBtn = modalBody.querySelector('.register-btn');
        if (registerBtn) {
            registerBtn.addEventListener('mouseenter', () => {
                registerBtn.style.boxShadow = '0 6px 25px rgba(108, 99, 255, 0.6)';
            });
            registerBtn.addEventListener('mouseleave', () => {
                registerBtn.style.boxShadow = '0 4px 15px rgba(108, 99, 255, 0.4)';
            });
        }

        modalEl.classList.remove('hidden');
        modalEl.classList.add('flex');
    }

    // Close Modal
    closeModalBtn.addEventListener('click', () => {
        modalEl.classList.add('hidden');
        modalEl.classList.remove('flex');
    });

    modalEl.addEventListener('click', (e) => {
        if (e.target === modalEl) {
            modalEl.classList.add('hidden');
            modalEl.classList.remove('flex');
        }
    });

    // Fetch Events from Google Calendar
    async function loadEvents() {
        try {
            const now = new Date().toISOString();
            const url = `https://www.googleapis.com/calendar/v3/calendars/${encodeURIComponent(CALENDAR_ID)}/events?key=${API_KEY}&timeMin=${now}&maxResults=10&singleEvents=true&orderBy=startTime`;

            const response = await fetch(url);

            if (response.status === 403) {
                console.warn('Calendar API returned 403 - using mock data');
                renderEvents(getMockEvents());
                return;
            }

            if (!response.ok) {
                throw new Error('Failed to fetch events');
            }

            const data = await response.json();
            renderEvents(data.items || []);
        } catch (error) {
            console.error('Error loading events:', error);
            loadingEl.classList.add('hidden');
            errorEl.classList.remove('hidden');
        }
    }

    // Initialize
    loadEvents();

    // Mock Events Data (for demonstration when API fails)
    function getMockEvents() {
        return [
            {
                id: '1',
                summary: 'Friday Night Magic',
                description: 'Join us for our weekly Friday Night Magic tournament! Standard format with prize support for top 8 players. Entry fee: $10. Bring your best deck and compete for booster packs and store credit.',
                location: 'PlayGames, Spartanburg, SC',
                start: { dateTime: '2024-12-27T18:00:00-05:00' },
                end: { dateTime: '2024-12-27T22:00:00-05:00' },
                attendees: '16-24 players expected'
            },
            {
                id: '2',
                summary: 'Pokémon Tournament',
                description: 'Monthly Pokémon TCG tournament with amazing prizes! Open to all skill levels. Standard format, 4-5 rounds of Swiss. Top 4 playoff. Prize pool includes booster boxes and exclusive promo cards.',
                location: 'PlayGames, Spartanburg, SC',
                start: { dateTime: '2024-12-28T14:00:00-05:00' },
                end: { dateTime: '2024-12-28T18:00:00-05:00' },
                attendees: '20-32 players expected'
            },
            {
                id: '3',
                summary: 'Commander Night',
                description: 'Casual Commander (EDH) night! Bring your favorite deck and play in a friendly, social environment. Multiple pods running throughout the evening. Free to play, prizes for random drawings.',
                location: 'PlayGames, Spartanburg, SC',
                start: { dateTime: '2024-12-30T19:00:00-05:00' },
                end: { dateTime: '2024-12-30T23:00:00-05:00' },
                attendees: 'Open play'
            },
            {
                id: '4',
                summary: 'Yu-Gi-Oh! League',
                description: 'Weekly Yu-Gi-Oh! league continues! Track your wins throughout the season for end-of-season prizes. Current format with banlist in effect. Entry: $5 per week.',
                location: 'PlayGames, Spartanburg, SC',
                start: { dateTime: '2025-01-02T18:30:00-05:00' },
                end: { dateTime: '2025-01-02T21:30:00-05:00' },
                attendees: '12-16 players expected'
            },
            {
                id: '5',
                summary: 'Modern Masters Draft',
                description: 'Special Modern Masters draft event! Rare opportunity to draft one of the most exciting sets. $30 entry includes all packs. Prize payout based on record. Reserve your spot early as space is limited!',
                location: 'PlayGames, Spartanburg, SC',
                start: { dateTime: '2025-01-04T17:00:00-05:00' },
                end: { dateTime: '2025-01-04T21:00:00-05:00' },
                attendees: '8 players (Limited spots!)'
            },
            {
                id: '6',
                summary: 'Board Game Night',
                description: 'Open board game night! Try new games from our library or bring your own. Great for families and newcomers. We\'ll have staff on hand to teach popular games like Catan, Ticket to Ride, and Splendor.',
                location: 'PlayGames, Spartanburg, SC',
                start: { dateTime: '2025-01-05T15:00:00-05:00' },
                end: { dateTime: '2025-01-05T20:00:00-05:00' },
                attendees: 'All welcome'
            }
        ];
    }

</script>