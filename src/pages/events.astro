---
import Layout from "../layouts/Layout.astro";
import '../styles/events.css';
---
<Layout title="PlayGames - Events | Spartanburg's Premier Card & Game Shop">
    <div id="eventsMain" class="events-page page-background">
        <div class="events-container">

            <!-- Header -->
            <header class="events-header">
                <h1 class="events-title gradient-text">
                    Upcoming Events
                </h1>
                <p class="events-subtitle">
                    Join us for tournaments, casual play, and community events. All skill levels welcome!
                </p>
            </header>

            <!-- Loading State -->
            <div id="loading" class="events-loading">
                <div class="loading-spinner"></div>
                <p class="loading-text">Loading events...</p>
            </div>

            <!-- Error State -->
            <div id="error" class="events-error hidden">
                <p class="error-message">Unable to load events from calendar</p>
                <p class="error-subtext">Showing example events below</p>
            </div>

            <!-- Events Grid -->
            <div id="events-grid" class="events-grid hidden"></div>

            <!-- No Events -->
            <div id="no-events" class="events-empty hidden">
                <svg class="events-empty-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                <p class="events-empty-title">No upcoming events scheduled</p>
                <p class="events-empty-subtitle">Check back soon for new events!</p>
            </div>
        </div>

        <!-- Modal -->
        <div id="event-modal" class="modal-overlay">
            <div id="modal-content" class="modal-content">
                <button
                    id="close-modal"
                    class="modal-close-btn"
                    aria-label="Close modal"
                >
                    <svg class="modal-close-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>

                <div id="modal-body" class="modal-body"></div>
            </div>
        </div>
    </div>
</Layout>

<script is:inline>
    const loadingEl = document.getElementById('loading');
    const errorEl = document.getElementById('error');
    const gridEl = document.getElementById('events-grid');
    const noEventsEl = document.getElementById('no-events');
    const modalEl = document.getElementById('event-modal');
    const modalBody = document.getElementById('modal-body');
    const closeModalBtn = document.getElementById('close-modal');

    // Google Calendar Configuration
    const CALENDAR_ID = "141c871f248f963c32f2a16fa07f3f9b7547a6af855219879ca68175c47925c9@group.calendar.google.com";
    const API_KEY = "AIzaSyDaJmNe4Gcfc4PTn-8VOZn1vtwb33FUlj0";

    // Date/Time Formatting Functions
    function formatDate(dateStr) {
        return new Date(dateStr).toLocaleDateString('en-US', {
            weekday: 'long',
            month: 'long',
            day: 'numeric',
            year: 'numeric'
        });
    }

    function formatTime(dateStr) {
        return new Date(dateStr).toLocaleTimeString('en-US', {
            hour: 'numeric',
            minute: '2-digit',
            hour12: true
        });
    }

    function daysUntil(dateStr) {
        const eventDate = new Date(dateStr);
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        eventDate.setHours(0, 0, 0, 0);

        const diff = Math.ceil((eventDate - today) / (1000 * 60 * 60 * 24));

        if (diff === 0) return 'Today';
        if (diff === 1) return 'Tomorrow';
        if (diff < 7 && diff > 0) return `In ${diff} days`;
        return '';
    }



    // Render Events to Grid
    function renderEvents(events) {
        loadingEl.classList.add('hidden');

        if (events.length === 0) {
            noEventsEl.classList.remove('hidden');
            return;
        }

        gridEl.classList.remove('hidden');
        gridEl.innerHTML = '';

        events.forEach(event => {
            const card = document.createElement('div');
            card.className = 'event-card';

            const daysBadge = daysUntil(event.start.dateTime);

            card.innerHTML = `
                ${daysBadge ? `
                    <div class="days-badge">
                        ${daysBadge}
                    </div>
                ` : ''}
                
                <h3 class="event-summary">
                    ${event.summary}
                </h3>
                
                <div class="event-info">
                    <div class="event-info-row">
                      <svg
                        class="event-info-row__icon event-info-row__icon--date"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                        ></path>
                      </svg>
                      <span>${formatDate(event.start.dateTime)}</span>
                    </div>

                    
                 <div class="event-info-row">
                        <svg 
                            class="event-info-row__icon event-info-row__icon--date" 
                            fill="none" 
                            stroke="currentColor"
                             viewBox="0 0 24 24">
                            <path 
                                stroke-linecap="round" 
                                stroke-linejoin="round" 
                                stroke-width="2" 
                                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                            ></path>
                        </svg>
                        <span>${formatTime(event.start.dateTime)} - ${formatTime(event.end.dateTime)}</span>
                    </div>
                    
                    ${event.location ? `
                 <div class="event-info-row">
                            <svg 
                                class="event-info-row__icon event-info-row__icon--date" 
                                fill="none" 
                                stroke="currentColor" 
                                viewBox="0 0 24 24"
                                >
                                <path 
                                    stroke-linecap="round" 
                                    stroke-linejoin="round" 
                                    stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                ></path>
                                <path 
                                    stroke-linecap="round" 
                                    stroke-linejoin="round" 
                                    stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                                ></path>
                            </svg>
                            <span>${event.location}</span>
                        </div>
                    ` : ''}
                </div>
                
                <p class="description">
                  ${event.description || 'Click for more details'}
                </p>
                
                <button class="details-btn">
                  View Details →
                </button>
            `;

            card.addEventListener('click', () => openModal(event));
            gridEl.appendChild(card);
        });
    }

    // Open Modal with Event Details
    function openModal(event) {
        const daysBadge = daysUntil(event.start.dateTime);

        modalBody.innerHTML = `
          ${daysBadge ? `
            <div class="days-modal-badge">
              ${daysBadge}
            </div>
          ` : ''}
        
          <h2 class="event-modal-title">
            ${event.summary}
          </h2>
        
          <div class="event-info-container">
            <div class="event-info-row">
              <svg class="event-info-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <div>
                <p class="event-info-label">Date</p>
                <p>${formatDate(event.start.dateTime)}</p>
              </div>
            </div>
        
            <div class="event-info-row">
              <svg class="event-info-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="event-info-label">Time</p>
                <p>${formatTime(event.start.dateTime)} – ${formatTime(event.end.dateTime)}</p>
              </div>
            </div>
        
            ${event.location ? `
              <div class="event-info-row">
                <svg class="event-info-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <div>
                  <p class="event-info-label">Location</p>
                  <p>${event.location}</p>
                </div>
              </div>
            ` : ''}
        
            ${event.attendees ? `
              <div class="event-info-row">
                <svg class="event-info-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1z" />
                </svg>
                <div>
                  <p class="event-info-label">Expected Attendance</p>
                  <p>${event.attendees}</p>
                </div>
              </div>
            ` : ''}
          </div>
        
          ${event.description ? `
            <div class="event-details">
              <h3 class="event-details-title">Event Details</h3>
              <p class="event-details-text">${event.description}</p>
            </div>
          ` : ''}
        
          ${event.htmlLink ? `
            <a href="${event.htmlLink}"
               target="_blank"
               rel="noopener noreferrer"
               class="event-action-btn">
              <svg class="event-action-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6v6L10 14" />
              </svg>
              View in Calendar
            </a>
          ` : ''}
        `;
        
        modalEl.classList.add('is-open');
    }

    // Close Modal
    closeModalBtn.addEventListener('click', () => {
        modalEl.classList.remove('is-open');
    });

    modalEl.addEventListener('click', (e) => {
        if (e.target === modalEl) {
            modalEl.classList.remove('is-open');
        }
    });

    // Fetch Events from Google Calendar
    async function loadEvents() {
        try {
            const now = new Date().toISOString();
            const url = `https://www.googleapis.com/calendar/v3/calendars/${encodeURIComponent(CALENDAR_ID)}/events?key=${API_KEY}&timeMin=${now}&maxResults=10&singleEvents=true&orderBy=startTime`;

            const response = await fetch(url);

            if (response.status === 403) {
                console.warn('Calendar API returned 403 - using mock data');
                renderEvents(getMockEvents());
                return;
            }

            if (!response.ok) {
                throw new Error('Failed to fetch events');
            }

            const data = await response.json();
            renderEvents(data.items || []);
        } catch (error) {
            console.error('Error loading events:', error);
            loadingEl.classList.add('hidden');
            errorEl.classList.remove('hidden');
        }
    }

    // Initialize
    loadEvents();

    // Mock Events Data (for demonstration when API fails)
    function getMockEvents() {
        return [
            {
                id: '1',
                summary: 'Friday Night Magic',
                description: 'Join us for our weekly Friday Night Magic tournament! Standard format with prize support for top 8 players. Entry fee: $10. Bring your best deck and compete for booster packs and store credit.',
                location: 'PlayGames, Spartanburg, SC',
                start: { dateTime: '2024-12-27T18:00:00-05:00' },
                end: { dateTime: '2024-12-27T22:00:00-05:00' },
                attendees: '16-24 players expected',
                htmlLink: 'http://localhost:4321/events'
            },
            {
                id: '2',
                summary: 'Pokémon Tournament',
                description: 'Monthly Pokémon TCG tournament with amazing prizes! Open to all skill levels. Standard format, 4-5 rounds of Swiss. Top 4 playoff. Prize pool includes booster boxes and exclusive promo cards.',
                location: 'PlayGames, Spartanburg, SC',
                start: { dateTime: '2024-12-28T14:00:00-05:00' },
                end: { dateTime: '2024-12-28T18:00:00-05:00' },
                attendees: '20-32 players expected'
            },
            {
                id: '3',
                summary: 'Commander Night',
                description: 'Casual Commander (EDH) night! Bring your favorite deck and play in a friendly, social environment. Multiple pods running throughout the evening. Free to play, prizes for random drawings.',
                location: 'PlayGames, Spartanburg, SC',
                start: { dateTime: '2024-12-30T19:00:00-05:00' },
                end: { dateTime: '2024-12-30T23:00:00-05:00' },
                attendees: 'Open play'
            },
            {
                id: '4',
                summary: 'Yu-Gi-Oh! League',
                description: 'Weekly Yu-Gi-Oh! league continues! Track your wins throughout the season for end-of-season prizes. Current format with banlist in effect. Entry: $5 per week.',
                location: 'PlayGames, Spartanburg, SC',
                start: { dateTime: '2025-01-02T18:30:00-05:00' },
                end: { dateTime: '2025-01-02T21:30:00-05:00' },
                attendees: '12-16 players expected'
            },
            {
                id: '5',
                summary: 'Modern Masters Draft',
                description: 'Special Modern Masters draft event! Rare opportunity to draft one of the most exciting sets. $30 entry includes all packs. Prize payout based on record. Reserve your spot early as space is limited!',
                location: 'PlayGames, Spartanburg, SC',
                start: { dateTime: '2025-01-04T17:00:00-05:00' },
                end: { dateTime: '2025-01-04T21:00:00-05:00' },
                attendees: '8 players (Limited spots!)'
            },
            {
                id: '6',
                summary: 'Board Game Night',
                description: 'Open board game night! Try new games from our library or bring your own. Great for families and newcomers. We\'ll have staff on hand to teach popular games like Catan, Ticket to Ride, and Splendor.',
                location: 'PlayGames, Spartanburg, SC',
                start: { dateTime: '2025-01-05T15:00:00-05:00' },
                end: { dateTime: '2025-01-05T20:00:00-05:00' },
                attendees: 'All welcome'
            }
        ];
    }

</script>